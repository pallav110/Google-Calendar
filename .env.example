# Copy this file to .env and fill in real values.

# Neon (or any) Postgres connection string.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Auth.js secret. Generate one with: npx auth secret
AUTH_SECRET="generate-a-random-32-byte-base64-string"
AUTH_URL="http://localhost:3000"

# Google OAuth credentials (optional). Leave blank to hide the Google button.
# Authorized redirect URI: <AUTH_URL>/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
