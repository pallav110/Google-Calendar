generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  timezone       String    @default("UTC")
  createdAt      DateTime  @default(now())

  accounts Account[]
  sessions Session[]
  events   Event[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// A single Event row models three cases:
//   one-off       -> rrule null, recurringEventId null
//   recurring base -> rrule set, recurringEventId null
//   override       -> recurringEventId points at the base; originalStartUtc marks which occurrence
// Deleting one occurrence = an override row with cancelled true.
model Event {
  id               String    @id @default(cuid())
  userId           String
  title            String    @default("(No title)")
  description      String?
  location         String?
  startUtc         DateTime
  endUtc           DateTime
  allDay           Boolean   @default(false)
  color            String    @default("blue")
  timezone         String    @default("UTC")
  rrule            String?
  recurringEventId String?
  originalStartUtc DateTime?
  cancelled        Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startUtc, endUtc])
  @@index([recurringEventId])
}
